{
    "css.customData": [".vscode/tailwind.json"],
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "editor.quickSuggestions": {
        "strings": "on"
    },
    "tailwindCSS.includeLanguages": {
        "plaintext": "html"
    },
    "chat.useNestedAgentsMdFiles": true,
